NODE_ENV=development
PORT=3000

# Foundation-required
# Matches docker-compose (postgres / 2662001), host port 5433 to avoid the local PG service on 5432
DATABASE_URL=postgres://postgres:2662001@localhost:5433/tradebot
REDIS_URL=redis://localhost:6380
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Used by later sub-plans (optional for foundation)
TELEGRAM_BOT_TOKEN=
ANTHROPIC_API_KEY=
BINANCE_USE_TESTNET=true
MAX_SINGLE_ORDER_USDT=500
MAX_DAILY_SPEND_USDT=2000
